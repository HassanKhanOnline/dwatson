---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  schema?: object[];
}

const { title, description, schema = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="https://dwatson.pk/static/frontend/DWatson/customtheme/en_US/images/logo.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Explore by D.Watson" />
    <meta name="twitter:card" content="summary" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Header />
    <main id="contentarea">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --dw-red: #b30000;
    --dw-blue: #1a53a1;
    --dw-text: #2b2b2b;
    --dw-muted: #666;
    --dw-border: #e5e5e5;
    --dw-bg-soft: #f7f7f7;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: var(--dw-text);
    line-height: 1.65;
    background: #fff;
  }
  .dw-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  a { color: var(--dw-blue); }
  h1, h2, h3 { line-height: 1.25; }
  img { max-width: 100%; }
</style>
