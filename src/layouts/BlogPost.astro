---
import Base from './Base.astro';
import RelatedProducts from '../components/RelatedProducts.astro';
import InlineProduct from '../components/InlineProduct.astro';
import SectionProducts from '../components/SectionProducts.astro';

interface Faq { q: string; a: string; }
interface Product { name: string; url: string; image: string; price: string; }
interface Section { match: string; label: string; category?: string; products: Product[]; }
type Block =
  | { type: 'html'; html: string }
  | { type: 'product'; product: Product }
  | { type: 'section'; section: Section };
interface Props {
  title: string;
  description: string;
  banner: string;
  bannerAlt: string;
  contentHtml: string;
  faqs: Faq[];
  related?: Product[];
  relatedHeading?: string;
  relatedCategory?: string;
  sections?: Section[];
  datePublished: string;
  dateModified: string;
}

const {
  title, description, banner, bannerAlt, contentHtml, faqs,
  related = [], relatedHeading = '', relatedCategory = '', sections = [],
  datePublished, dateModified,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Display prices are whole rupees ("Rs. 1,140") — strip everything non-digit,
// including the dot in "Rs." and thousands commas.
const priceToNumber = (s: string) => Number(String(s).replace(/[^0-9]/g, '')) || undefined;

// Split the article body at <h2> section breaks and drop 1 (short posts) or 2
// (long posts) "featured pick" cards mid-article, at the section boundaries
// nearest the target fractions. Skips the intro and the FAQ/end region.
function buildBlocks(html: string, products: Product[]): Block[] {
  if (!products.length) return [{ type: 'html', html }];
  const len = html.length;
  const inWindow = (idx: number) => idx > len * 0.15 && idx < len * 0.8;
  const wantN = len > 18000 ? 2 : 1;

  // Prefer <h2> section breaks; fall back to <h3> for posts (e.g. specialist
  // round-ups) whose mid-article breaks are all <h3>.
  let heads = [...html.matchAll(/<h2[\s>]/g)].map((m) => m.index as number).filter(inWindow);
  if (heads.length < wantN) {
    heads = [...html.matchAll(/<h[23][\s>]/g)].map((m) => m.index as number).filter(inWindow);
  }
  if (!heads.length) return [{ type: 'html', html }];

  const n = Math.min(wantN, products.length, heads.length);
  const fractions = n === 1 ? [0.45] : [0.33, 0.66];

  const cuts: number[] = [];
  for (const f of fractions.slice(0, n)) {
    const target = len * f;
    let best: number | null = null;
    let bestD = Infinity;
    for (const idx of heads) {
      if (cuts.includes(idx)) continue;
      const d = Math.abs(idx - target);
      if (d < bestD) { bestD = d; best = idx; }
    }
    if (best != null) cuts.push(best);
  }
  cuts.sort((a, b) => a - b);

  const blocks: Block[] = [];
  let prev = 0;
  cuts.forEach((c, i) => {
    blocks.push({ type: 'html', html: html.slice(prev, c) });
    blocks.push({ type: 'product', product: products[i] });
    prev = c;
  });
  blocks.push({ type: 'html', html: html.slice(prev) });
  return blocks;
}

// When a post has curated shoppable sections, inject a matching product row at
// the end of each section (before the next heading), matched by heading text.
function buildSectionBlocks(html: string, secs: Section[]): Block[] {
  const heads = [...html.matchAll(/<(h2|h3)\b[^>]*>([\s\S]*?)<\/\1>/g)].map((m) => ({
    index: m.index as number,
    text: m[2].replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim(),
  }));
  if (!heads.length) return [{ type: 'html', html }];

  const blocks: Block[] = [];
  if (heads[0].index > 0) blocks.push({ type: 'html', html: html.slice(0, heads[0].index) });

  heads.forEach((h, i) => {
    const end = i + 1 < heads.length ? heads[i + 1].index : html.length;
    blocks.push({ type: 'html', html: html.slice(h.index, end) });
    const sec = secs.find((s) => h.text.toLowerCase().includes(s.match.toLowerCase()));
    if (sec) blocks.push({ type: 'section', section: sec });
  });
  return blocks;
}

const blocks = sections.length
  ? buildSectionBlocks(contentHtml, sections)
  : buildBlocks(contentHtml, related);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    ...(banner ? { image: banner } : {}),
    datePublished,
    dateModified,
    mainEntityOfPage: canonical,
    author: { '@type': 'Organization', name: 'D.Watson Chemist', url: 'https://dwatson.pk/' },
    publisher: {
      '@type': 'Organization',
      name: 'D.Watson Chemist',
      url: 'https://dwatson.pk/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://dwatson.pk/static/frontend/DWatson/customtheme/en_US/images/logo.svg',
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Explore', item: 'https://explore.dwatson.pk/' },
      { '@type': 'ListItem', position: 2, name: 'Health Blog', item: 'https://explore.dwatson.pk/blog/' },
      { '@type': 'ListItem', position: 3, name: title, item: canonical },
    ],
  },
  ...(faqs.length
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }]
    : []),
  ...(related.length
    ? [{
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        name: relatedHeading,
        numberOfItems: related.length,
        itemListElement: related.map((p, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          item: {
            '@type': 'Product',
            name: p.name,
            url: p.url,
            image: p.image,
            offers: {
              '@type': 'Offer',
              ...(priceToNumber(p.price) ? { price: priceToNumber(p.price), priceCurrency: 'PKR' } : {}),
              availability: 'https://schema.org/InStock',
              seller: { '@type': 'Organization', name: 'D.Watson', url: 'https://dwatson.pk/' },
            },
          },
        })),
      }]
    : []),
  ...sections.map((sec) => ({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: sec.label,
    numberOfItems: sec.products.length,
    itemListElement: sec.products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Product',
        name: p.name,
        url: p.url,
        image: p.image,
        offers: {
          '@type': 'Offer',
          ...(priceToNumber(p.price) ? { price: priceToNumber(p.price), priceCurrency: 'PKR' } : {}),
          availability: 'https://schema.org/InStock',
          seller: { '@type': 'Organization', name: 'D.Watson', url: 'https://dwatson.pk/' },
        },
      },
    })),
  })),
];
---

<Base title={`${title} | Explore by D.Watson`} description={description} schema={schema}>
  <article class="dw-container post">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Explore</a> <span>›</span>
      <a href="/blog/">Health Blog</a> <span>›</span>
      <span>{title}</span>
    </nav>

    <h1>{title}</h1>
    <p class="byline">By the D.Watson Health Team · dwatson.pk</p>

    {banner && (
      <img class="post-hero" src={banner} alt={bannerAlt} width="800" height="420" />
    )}

    <div class="post-body">
      {blocks.map((b) => (
        b.type === 'html' ? <Fragment set:html={b.html} />
        : b.type === 'section' ? <SectionProducts label={b.section.label} category={b.section.category} products={b.section.products} />
        : <InlineProduct product={b.product} />
      ))}
    </div>

    <RelatedProducts heading={relatedHeading} category={relatedCategory} products={related} />

    <p class="disclaimer">
      <strong>Disclaimer:</strong> This article is for general information only and is not a
      substitute for professional medical advice, diagnosis, or treatment. Always consult a
      qualified pharmacist or physician for concerns about your health or medication.
    </p>

    <a class="back-link" href="/blog/">← Back to all health guides</a>
  </article>
</Base>

<style>
  .post { max-width: 800px; padding-top: 2rem; }
  .crumbs { font-size: 0.85rem; color: var(--dw-muted); margin-bottom: 1rem; }
  .crumbs a { color: var(--dw-muted); }
  .crumbs span { margin: 0 0.25rem; }
  h1 { font-size: 2rem; margin: 0 0 0.5rem; color: var(--dw-text); }
  .byline {
    font-size: 0.9rem;
    color: var(--dw-muted);
    border-bottom: 2px solid var(--dw-red);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }
  .post-hero {
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin-bottom: 1.75rem;
  }

  /* Rendered article body */
  .post-body :global(h2) {
    font-size: 1.5rem;
    margin: 2.25rem 0 0.75rem;
    color: var(--dw-text);
  }
  .post-body :global(h3) {
    font-size: 1.2rem;
    margin: 1.75rem 0 0.6rem;
    color: var(--dw-text);
  }
  .post-body :global(p) { margin: 0.85rem 0; }
  .post-body :global(ul),
  .post-body :global(ol) { margin: 0.85rem 0; padding-left: 1.5rem; }
  .post-body :global(li) { margin: 0.35rem 0; }
  .post-body :global(a) { color: var(--dw-blue); }
  .post-body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem auto;
  }
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.25rem 0;
  }
  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--dw-border);
    padding: 0.55rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .post-body :global(th) { background: var(--dw-bg-soft); }
  .post-body :global(blockquote) {
    margin: 1.25rem 0;
    padding: 0.5rem 1rem;
    border-left: 3px solid var(--dw-red);
    background: var(--dw-bg-soft);
    color: var(--dw-text);
  }
  .post-body :global(details) {
    border: 1px solid var(--dw-border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.6rem;
    background: var(--dw-bg-soft);
  }
  .post-body :global(summary) { font-weight: 700; cursor: pointer; }
  .post-body :global(details p) { margin: 0.6rem 0 0; }

  .disclaimer {
    margin-top: 2.5rem;
    font-size: 0.82rem;
    color: var(--dw-muted);
    background: var(--dw-bg-soft);
    border-left: 3px solid var(--dw-red);
    padding: 0.9rem 1.1rem;
  }
  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-weight: 700;
    color: var(--dw-red);
    text-decoration: none;
  }
  .back-link:hover { text-decoration: underline; }
</style>
