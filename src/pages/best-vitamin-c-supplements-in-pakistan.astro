  { name: 'NF Nutra C Plus C500 + Zinc Tablets 30s', url: 'https://dwatson.pk/nf-nutra-c-plus-c500-zinc-tablets-30s.html', price: 690, display: 'Rs. 690', badge: 'Best for Immunity' },
  { name: 'Core C Sachets 1000mg 30s (Sugar Free)', url: 'https://dwatson.pk/core-c-sachets-1000mg-30s-sugar-free.html', price: 900, display: 'Rs. 900', badge: 'Best Sugar-Free' },
  { name: 'NF Extra C Tablets 90s', url: 'https://dwatson.pk/nf-extra-c-tabs-90s.html', price: 1800, display: 'Rs. 1,800', badge: 'Best Bulk Buy' },
  { name: 'GH C-500 Vitamin C 500mg Tablets 30s', url: 'https://dwatson.pk/glr-c-500-vitamin-c-500mg-tablets-30s.html', price: 1195, display: 'Rs. 1,195' },
  { name: 'Askob C 500mg Tablets 30s', url: 'https://dwatson.pk/askob-c-500mg-tablets-30s.html', price: 1140, display: 'Rs. 1,140' },
