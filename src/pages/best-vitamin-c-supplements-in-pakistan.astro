      <tr><td>3</td><td>Core C Sachets 30s</td><td>1000mg</td><td>Sugar-free sachets</td><td>Rs. 900</td></tr>
      <tr><td>4</td><td>NF Extra C 90s</td><td>500mg</td><td>Tablets (3-month)</td><td>Rs. 1,800</td></tr>
      <tr><td>5</td><td>GH C-500 30s</td><td>500mg</td><td>Tablets</td><td>Rs. 1,195</td></tr>
      <tr><td>6</td><td>Askob C 30s</td><td>500mg</td><td>Tablets</td><td>Rs. 1,140</td></tr>
      <tr><td>7</td><td>NF Nutra C Plus 60s</td><td>500mg</td><td>Tablets (2-month)</td><td>Rs. 1,150</td></tr>
      <tr><td>8</td><td>Nutribase Mycee Plus 30s</td><td>500mg</td><td>Tablets</td><td>Rs. 899</td></tr>
      <tr><td>9</td><td>NF Extra C 30s</td><td>500mg</td><td>Tablets</td><td>Rs. 690</td></tr>
