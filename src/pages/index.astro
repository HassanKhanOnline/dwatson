---
import Base from '../layouts/Base.astro';
import posts from '../data/posts.json';

const blogPosts = posts.slice(0, 6);

const articles = [
  {
    slug: '/best-glucose-monitors-in-pakistan/',
    category: 'Healthcare Devices',
    title: '10 Best Glucose Monitors & Test Strips in Pakistan (2026)',
    description: 'Accu-Chek Instant vs Active vs Guide — and why the per-strip running cost matters more than the meter price.',
    date: 'July 5, 2026',
  },
  {
    slug: '/best-mens-perfumes-in-pakistan/',
    category: 'Fragrances',
    title: "10 Best Men's Perfumes in Pakistan (2026)",
    description: 'Viral Afnan 9PM, entry-level oud, luxury Acqua di Parma, and the best bottles under Rs. 5,000.',
    date: 'July 5, 2026',
  },
  {
    slug: '/best-whitening-serums-and-creams-in-pakistan/',
    category: 'Skin Care',
    title: '10 Best Whitening & Brightening Serums and Creams in Pakistan (2026)',
    description: 'Safe, registered pharmacy picks for dark spots and uneven tone — and the bazaar creams to avoid.',
    date: 'July 5, 2026',
  },
  {
    slug: '/best-anti-dandruff-shampoos-in-pakistan/',
    category: 'Personal Care',
    title: '10 Best Anti-Dandruff Shampoos in Pakistan (2026)',
    description: 'Alpecin, Bionnex, coal tar for stubborn flaking, and budget picks from Rs. 650 — plus the technique most people skip.',
    date: 'July 5, 2026',
  },
  {
    slug: '/best-nebulizers-in-pakistan/',
    category: 'Healthcare Devices',
    title: '10 Best Nebulizers in Pakistan (2026)',
    description: 'Compressor vs mesh, child-friendly picks, and load-shedding-proof battery options from Rs. 6,200.',
    date: 'July 5, 2026',
  },
  {
    slug: '/best-sunscreens-in-pakistan/',
    category: 'Skin Care',
    title: '10 Best Sunscreens in Pakistan (2026)',
    description: 'From Rs. 750 budget SPF 60s to Korean SPF 50+ favourites — pharmacist-reviewed picks for the Pakistani sun.',
    date: 'July 4, 2026',
  },
  {
    slug: '/best-blood-pressure-monitors-in-pakistan/',
    category: 'Healthcare Devices',
    title: '10 Best Blood Pressure Monitors in Pakistan (2026)',
    description: 'Digital vs aneroid vs mercury — which BP monitor to buy for home use, elderly parents, or a clinic.',
    date: 'July 4, 2026',
  },
  {
    slug: '/best-vitamin-c-supplements-in-pakistan/',
    category: 'Health Supplements',
    title: '10 Best Vitamin C Supplements in Pakistan (2026)',
    description: 'Tablets, sugar-free sachets, and vitamin C + zinc combos compared on dose and price per day.',
    date: 'July 4, 2026',
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Explore by D.Watson',
    url: 'https://explore.dwatson.pk/',
    description:
      'Buying guides and product round-ups from D.Watson Chemist, Pakistan.',
    publisher: {
      '@type': 'Organization',
      name: 'D.Watson Chemist',
      url: 'https://dwatson.pk/',
    },
  },
];
---

<Base
  title="Explore by D.Watson — Buying Guides & Best-Of Lists for Health, Beauty & Wellness in Pakistan"
  description="Pharmacist-reviewed buying guides from D.Watson: the best sunscreens, supplements, healthcare devices, and personal care products available in Pakistan, with live prices and stock."
  schema={schema}
>
  <section class="hero">
    <div class="dw-container">
      <h1>Explore by D.Watson</h1>
      <p>
        Honest, pharmacist-reviewed buying guides for health, beauty, and wellness in
        Pakistan. Every product we recommend is in stock at
        <a href="https://dwatson.pk/">dwatson.pk</a> with nationwide delivery.
      </p>
    </div>
  </section>

  <section class="dw-container">
    <h2 class="section-title">Latest Guides</h2>
    <div class="grid">
      {articles.map((a) => (
        <a class="card" href={a.slug}>
          <span class="cat">{a.category}</span>
          <h3>{a.title}</h3>
          <p>{a.description}</p>
          <span class="meta">Updated {a.date} · D.Watson Pharmacy Team</span>
        </a>
      ))}
    </div>
  </section>

  <section class="dw-container">
    <h2 class="section-title">From the Health Blog</h2>
    <div class="blog-strip">
      {blogPosts.map((p) => (
        <a class="mini-card" href={`/blog/${p.slug}/`}>
          {p.banner && (
            <div class="mini-card__img">
              <img src={p.banner} alt={p.bannerAlt} loading="lazy" width="300" height="170" />
            </div>
          )}
          <h3>{p.title}</h3>
        </a>
      ))}
    </div>
    <p class="blog-more"><a href="/blog/">Browse all health guides →</a></p>
  </section>

  <section class="dw-container about">
    <h2 class="section-title">Why trust these guides?</h2>
    <p>
      D.Watson Chemist has served Islamabad and Rawalpindi since 1980 and
      is one of Pakistan's largest pharmacy retailers. Our guides are written with input from
      our in-store pharmacy team, compare only products we actually stock and dispense daily,
      and show real shelf prices — so what you read here is what you can order today on
      <a href="https://dwatson.pk/">dwatson.pk</a>.
    </p>
  </section>
</Base>

<style>
  .hero {
    background: linear-gradient(135deg, var(--dw-red), #7c0000);
    color: #fff;
    padding: 3.5rem 0;
    text-align: center;
  }
  .hero h1 { font-size: 2.4rem; margin: 0 0 0.75rem; }
  .hero p { max-width: 620px; margin: 0 auto; font-size: 1.05rem; opacity: 0.95; }
  .hero a { color: #ffd9d9; }

  .section-title {
    margin-top: 3rem;
    font-size: 1.5rem;
    border-left: 4px solid var(--dw-red);
    padding-left: 0.75rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card {
    display: block;
    border: 1px solid var(--dw-border);
    border-radius: 8px;
    padding: 1.4rem 1.5rem;
    text-decoration: none;
    color: var(--dw-text);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
    background: #fff;
  }
  .card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }
  .cat {
    display: inline-block;
    color: var(--dw-red);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .card h3 { margin: 0 0 0.5rem; font-size: 1.15rem; color: var(--dw-blue); }
  .card p { margin: 0 0 0.75rem; font-size: 0.92rem; color: var(--dw-muted); }
  .meta { font-size: 0.78rem; color: #999; }
  .about p { max-width: 760px; }

  .blog-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .mini-card {
    display: block;
    border: 1px solid var(--dw-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: var(--dw-text);
    background: #fff;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .mini-card:hover { box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1); transform: translateY(-2px); }
  .mini-card__img { aspect-ratio: 16 / 9; overflow: hidden; background: var(--dw-bg-soft); }
  .mini-card__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mini-card h3 { margin: 0; padding: 0.85rem 1rem 1.1rem; font-size: 0.98rem; color: var(--dw-blue); line-height: 1.3; }
  .blog-more { margin-top: 1.25rem; }
  .blog-more a { font-weight: 700; color: var(--dw-red); text-decoration: none; }
  .blog-more a:hover { text-decoration: underline; }
</style>
