<header class="dw-header">
  <div class="dw-topbar">
    <div class="dw-container dw-topbar-inner">
      <a class="dw-logo" href="/" aria-label="D.Watson Explore — home">
        <img src="https://dwatson.pk/static/frontend/DWatson/customtheme/en_US/images/logo.svg" alt="D.Watson" width="170" height="46" />
        <span class="dw-logo-sub">Explore</span>
      </a>
      <div class="dw-topbar-actions">
        <a href="https://dwatson.pk/customer/account/login/" class="dw-signin">Sign In</a>
        <a href="https://dwatson.pk/checkout/cart/" class="dw-cart" aria-label="My Cart">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 7h12l1 13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1L6 7Z" />
            <path d="M9 10V6a3 3 0 0 1 6 0v4" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <nav class="dw-nav" aria-label="Store categories">
    <div class="dw-container">
      <ul class="dw-nav-list">
        {nav.map((item) => (
          <li class={`dw-nav-item ${item.children.length ? 'has-children' : ''}`}>
            <a href={item.href}>{item.label}</a>
            {item.children.length > 0 && (
              <ul class="dw-submenu">
                {item.children.map((child) => (
                  <li><a href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li class="dw-nav-item dw-nav-blog">
          <a href="/blog/">Health Blog</a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<style>
  .dw-topbar {
    background: var(--dw-red);
    color: #fff;
  }
  .dw-topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
  }
  .dw-logo {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    text-decoration: none;
  }
  .dw-logo img {
    display: block;
    height: auto;
  }
  .dw-logo-sub {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.92;
  }
  .dw-topbar-actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .dw-signin {
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .dw-signin:hover { text-decoration: underline; }
  .dw-cart { color: #fff; display: inline-flex; }

  .dw-nav {
    background: #fff;
    border-bottom: 1px solid #e5e5e5;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
  }
  .dw-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
  }
  .dw-nav-item { position: relative; }
  .dw-nav-item > a {
    display: block;
    padding: 0.85rem 0.55rem;
    color: var(--dw-blue);
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .dw-nav-item > a:hover { color: var(--dw-red); }
  .dw-nav-blog > a { color: var(--dw-red); }
  .dw-nav-blog > a:hover { text-decoration: underline; }

  .dw-submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 50;
    min-width: 240px;
    margin: 0;
    padding: 0.4rem 0;
    list-style: none;
    background: #fff;
    border: 1px solid #e5e5e5;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
  }
  .dw-nav-item.has-children:hover .dw-submenu,
  .dw-nav-item.has-children:focus-within .dw-submenu {
    display: block;
  }
  .dw-submenu a {
    display: block;
    padding: 0.5rem 1rem;
    color: #333;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .dw-submenu a:hover {
    background: #f6f6f6;
    color: var(--dw-red);
  }

  @media (max-width: 900px) {
    .dw-nav-list {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .dw-submenu { display: none !important; }
  }
</style>
