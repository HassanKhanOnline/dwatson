---
interface Product {
  name: string;
  url: string;
  image: string;
  price: string;
}
interface Props { product: Product; }
const { product } = Astro.props;
---

<aside class="inline-product">
  <a class="ip-thumb" href={product.url} rel="noopener" tabindex="-1" aria-hidden="true">
    <img src={product.image} alt={product.name} width="90" height="90" loading="lazy" />
  </a>
  <div class="ip-body">
    <span class="ip-label">Featured pick from D.Watson</span>
    <a class="ip-name" href={product.url} rel="noopener">{product.name}</a>
    <span class="ip-price">{product.price}</span>
  </div>
  <a class="ip-btn" href={product.url} rel="noopener">View →</a>
</aside>

<style>
  .inline-product {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.75rem 0;
    padding: 0.85rem 1rem;
    border: 1px solid var(--dw-border);
    border-left: 4px solid var(--dw-red);
    border-radius: 8px;
    background: var(--dw-bg-soft);
  }
  .ip-thumb {
    flex: 0 0 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1px solid var(--dw-border);
    border-radius: 6px;
    padding: 0.3rem;
  }
  .ip-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .ip-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.15rem; }
  .ip-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--dw-red);
  }
  .ip-name { font-size: 0.98rem; font-weight: 700; color: var(--dw-text); text-decoration: none; line-height: 1.3; }
  .ip-name:hover { color: var(--dw-red); }
  .ip-price { font-size: 0.92rem; font-weight: 700; color: var(--dw-red); }
  .ip-btn {
    flex: 0 0 auto;
    align-self: center;
    background: var(--dw-red);
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    white-space: nowrap;
  }
  .ip-btn:hover { background: #8f0000; }

  @media (max-width: 520px) {
    .inline-product { flex-wrap: wrap; }
    .ip-btn { width: 100%; text-align: center; }
  }
</style>
